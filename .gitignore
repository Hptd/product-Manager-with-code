# ===========================
# 依赖包目录 - 无需上传
# ===========================
node_modules/
**/node_modules/

# ===========================
# 构建输出 - 无需上传
# ===========================
dist/
**/dist/
build/
**/build/

# ===========================
# 本地配置和缓存
# ===========================
.qwen/
*.local
.env.local
.env.*.local

# ===========================
# 日志文件
# ===========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================
# 编辑器文件
# ===========================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===========================
# 系统文件
# ===========================
.DS_Store
Thumbs.db
$null

# ===========================
# 环境变量（如有敏感信息）
# ===========================
# .env
# .env.production

# ===========================
# 临时文件
# ===========================
*.tmp
*.temp
tmp/
temp/

# ===========================
# Axure 临时文件（可选）
# ===========================
# axure/projects/uploads/
# axure/**/*.bak
